# =============================================================================
# Supabase (Pflicht)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# KI-Provider — wähle EINEN und konfiguriere ihn
# =============================================================================

# Welcher Provider soll verwendet werden?
# Werte: ollama | lmstudio | claude | mistral | gemini
AI_PROVIDER=ollama

# Optionale Überschreibungen (werden sonst auf Standardwerte gesetzt):
# AI_MODEL=llava              # Ollama: llava, llama3.2-vision, moondream
                               # LM Studio: (Name des geladenen Modells)
                               # Claude: claude-haiku-4-5-20251001, claude-sonnet-4-6
                               # Mistral: pixtral-12b-2409, mistral-large-latest
                               # Gemini: gemini-1.5-flash, gemini-1.5-pro
# AI_BASE_URL=                 # Standard-URLs werden automatisch gesetzt
# AI_API_KEY=                  # Nur für Cloud-Provider nötig

# =============================================================================
# Lokale Provider (kein API-Key nötig)
# =============================================================================

# --- OPTION A: Ollama (empfohlen für lokal) ---
# Download: https://ollama.com
# Setup:    ollama pull llava
# AI_PROVIDER=ollama
# AI_MODEL=llava

# --- OPTION B: LM Studio ---
# Download: https://lmstudio.ai
# Setup:    Modell laden → Local Server starten (Port 1234)
# AI_PROVIDER=lmstudio
# AI_MODEL=loaded-model

# =============================================================================
# Cloud-Provider (API-Key erforderlich)
# =============================================================================

# --- OPTION C: Anthropic Claude ---
# API-Key:  https://console.anthropic.com
# AI_PROVIDER=claude
# AI_MODEL=claude-haiku-4-5-20251001
# AI_API_KEY=sk-ant-...

# --- OPTION D: Mistral AI ---
# API-Key:  https://console.mistral.ai
# AI_PROVIDER=mistral
# AI_MODEL=pixtral-12b-2409
# AI_API_KEY=...

# --- OPTION E: Google Gemini ---
# API-Key:  https://aistudio.google.com/app/apikey
# AI_PROVIDER=gemini
# AI_MODEL=gemini-1.5-flash
# AI_API_KEY=AIza...
