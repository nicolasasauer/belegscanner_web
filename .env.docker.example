# ══════════════════════════════════════════════════════════════════
#  Belegscanner Web — Docker Environment
#  Kopiere diese Datei: cp .env.docker.example .env.docker
#  Dann die Werte eintragen und fertig!
# ══════════════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────────────
# Werte findest du unter: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key-hier

# ── App ────────────────────────────────────────────────────────────
PORT=3000

# ── KI / OCR Anbieter ─────────────────────────────────────────────
# Optionen: ollama | lmstudio | claude | mistral | gemini

# Mit Ollama-Container (docker compose --profile ai up):
AI_PROVIDER=ollama
AI_MODEL=llava
AI_BASE_URL=http://ollama:11434
AI_API_KEY=

# Mit externem Ollama (z.B. direkt auf dem Pi ohne Docker):
# AI_PROVIDER=ollama
# AI_MODEL=llava
# AI_BASE_URL=http://host.docker.internal:11434
# AI_API_KEY=

# Mit Claude API:
# AI_PROVIDER=claude
# AI_MODEL=claude-haiku-4-5-20251001
# AI_BASE_URL=
# AI_API_KEY=sk-ant-...

# Mit Mistral:
# AI_PROVIDER=mistral
# AI_MODEL=pixtral-12b-2409
# AI_BASE_URL=
# AI_API_KEY=dein-mistral-key

# Mit Gemini:
# AI_PROVIDER=gemini
# AI_MODEL=gemini-2.0-flash
# AI_BASE_URL=
# AI_API_KEY=dein-gemini-key

# Ohne KI (manuell eintragen):
# AI_PROVIDER=
# AI_MODEL=
# AI_BASE_URL=
# AI_API_KEY=
